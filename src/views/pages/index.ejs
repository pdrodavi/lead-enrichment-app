<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Lead Enrichment Tool</title>
  <style>
    /* Melhorias de toque em mobile */
    @media (max-width: 640px) {
      button, .clickable, [onclick] {
        min-height: 44px;
      }
    }
    
    /* Quebra de texto em todas as células da tabela */
    td, th {
      word-break: break-word;
      max-width: 250px;
    }
    
    /* Rolagem suave para a tabela */
    .overflow-x-auto {
      -webkit-overflow-scrolling: touch;
    }
    
    /* Animações suaves */
    .transition-smooth {
      transition: all 0.2s ease-in-out;
    }
  </style>
</head>
<body class="bg-gray-50 p-2 sm:p-4 md:p-6 lg:p-8">
  <div class="max-w-7xl mx-auto bg-white rounded-lg shadow-md">
    <!-- Cabeçalho responsivo -->
    <div class="p-4 sm:p-6 border-b border-gray-200">
      <h1 class="text-xl sm:text-2xl md:text-3xl font-bold text-gray-800">📊 Lead Enrichment Tool</h1>
      <p class="text-xs sm:text-sm text-gray-500 mt-1">Enriqueça e gerencie seus leads com informações avançadas</p>
    </div>

    <div class="p-4 sm:p-6">
      <!-- Tabela de Leads -->
      <% if (Array.isArray(leads) && leads.length > 0) { %>
        <div class="mb-8">
          <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-4 gap-2">
            <h2 class="text-lg sm:text-xl font-semibold text-gray-800">📋 Leads Cadastrados</h2>
            <span class="text-xs sm:text-sm text-gray-500 bg-gray-100 px-2 py-1 rounded-full">
              Total: <%= leads.length %> lead(s)
            </span>
          </div>
          
          <!-- Tabela Responsiva -->
          <div class="overflow-x-auto shadow-md rounded-lg border border-gray-200">
            <div class="min-w-full inline-block align-middle">
              <div class="overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                  <thead class="bg-blue-600">
                    <tr>
                      <!-- Colunas ESSENCIAIS (sempre visíveis) -->
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider">ID</th>
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider">E-mail</th>
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider">Nome</th>
                      
                      <!-- Coluna visível a partir de SM (640px) -->
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider hidden sm:table-cell">Domínio</th>
                      
                      <!-- Coluna visível a partir de MD (768px) -->
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider hidden md:table-cell">MX</th>
                      
                      <!-- Colunas visíveis a partir de LG (1024px) -->
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider hidden lg:table-cell">Status</th>
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider hidden lg:table-cell">Techs</th>
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-left text-xs font-medium text-white uppercase tracking-wider hidden lg:table-cell">E-mails Expostos</th>
                      
                      <!-- Ações sempre visíveis -->
                      <th scope="col" class="px-2 sm:px-3 py-2 sm:py-3 text-center text-xs font-medium text-white uppercase tracking-wider">Ações</th>
                    </tr>
                  </thead>
                  <tbody class="bg-white divide-y divide-gray-200">
                    <% if (Array.isArray(leads) && leads.length > 0) { %>
                      <% leads.forEach(function(item, idx) { %>
                        <tr class="<%= idx % 2 === 0 ? 'bg-gray-50' : 'bg-white' %> hover:bg-blue-50 transition-smooth cursor-pointer"
                            data-lead-id="<%= item.id %>" title="Clique para ver detalhes">
                          
                          <!-- ID -->
                          <td class="px-2 sm:px-3 py-2 text-xs text-gray-800 font-mono"><%= item.id %></td>
                          
                          <!-- E-mail (mascarado se disponível) -->
                          <td class="px-2 sm:px-3 py-2 text-xs text-gray-800 break-words"><%= item.emailMasked || item.email || '—' %></td>
                          
                          <!-- Nome -->
                          <td class="px-2 sm:px-3 py-2 text-xs text-gray-800 break-words font-medium"><%= item.name || '—' %></td>
                          
                          <!-- Domínio (escondido em mobile) -->
                          <td class="px-2 sm:px-3 py-2 text-xs text-gray-800 break-words hidden sm:table-cell"><%= item.domain || '—' %></td>
                          
                          <!-- MX Status (escondido até MD) -->
                          <td class="px-2 sm:px-3 py-2 text-xs hidden md:table-cell">
                            <% if (item.mxStatus === true) { %>
                              <span class="text-green-600 font-bold">✓ Sim</span>
                            <% } else if (item.mxStatus === false) { %>
                              <span class="text-red-500">✗ Não</span>
                            <% } else { %>
                              <span class="text-gray-400 italic">—</span>
                            <% } %>
                          </td>
                          
                          <!-- Status (escondido até LG) -->
                          <td class="px-2 sm:px-3 py-2 text-xs hidden lg:table-cell">
                            <% if (item.status) { %>
                              <span class="inline-block px-2 py-0.5 rounded-full text-xs 
                                <%= item.status === 'enriched' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                                <%= item.status %>
                              </span>
                            <% } else { %>
                              <span class="text-gray-400 italic">—</span>
                            <% } %>
                          </td>
                          
                          <!-- Tecnologias (escondido até LG) -->
                          <td class="px-2 sm:px-3 py-2 text-xs hidden lg:table-cell">
                            <% if (item.technologies && Array.isArray(item.technologies) && item.technologies.length > 0) { %>
                              <span class="text-blue-600 font-medium"><%= item.technologies.length %> item(s)</span>
                            <% } else { %>
                              <span class="text-gray-400 italic">—</span>
                            <% } %>
                          </td>
                          
                          <!-- E-mails Expostos (escondido até LG) -->
                          <td class="px-2 sm:px-3 py-2 text-xs hidden lg:table-cell">
                            <% if (item.exposedEmails && Array.isArray(item.exposedEmails) && item.exposedEmails.length > 0) { %>
                              <span class="text-red-600 font-medium"><%= item.exposedEmails.length %> e-mail(s)</span>
                            <% } else { %>
                              <span class="text-gray-400 italic">—</span>
                            <% } %>
                          </td>
                          
                          <!-- Ações -->
                          <td class="px-2 sm:px-3 py-2 text-center whitespace-nowrap">
                            <button onclick="event.stopPropagation(); openEditById(<%= item.id %>)" 
                                    class="bg-yellow-500 text-white text-xs px-2 py-1 rounded hover:bg-yellow-600 transition-smooth mr-1"
                                    title="Editar lead">
                              ✎ Editar
                            </button>
                            <button onclick="event.stopPropagation(); deleteLead(<%= item.id %>)" 
                                    class="bg-red-500 text-white text-xs px-2 py-1 rounded hover:bg-red-700 transition-smooth"
                                    title="Excluir lead">
                              ✕ Excluir
                            </button>
                          </td>
                        </tr>
                      <% }); %>
                    <% } else { %>
                      <tr>
                        <td colspan="9" class="px-3 py-8 text-center text-gray-400">
                          Nenhum lead encontrado
                        </td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            </div>
            
            <!-- Aviso para dispositivos móveis -->
            <div class="text-xs text-gray-400 p-2 text-center border-t border-gray-200 bg-gray-50 sm:hidden">
              ↳ Role horizontalmente para ver mais informações
            </div>
          </div>
        </div>
      <% } else if (Array.isArray(leads) && leads.length === 0) { %>
        <div class="mb-8 p-6 bg-gray-50 rounded-lg border border-gray-200 text-center">
          <p class="text-gray-400">📭 Nenhum lead encontrado. Use o formulário abaixo para enriquecer um novo lead.</p>
        </div>
      <% } %>

      <!-- Formulário de Enriquecimento - Totalmente Responsivo -->
      <div class="mb-6">
        <h2 class="text-lg sm:text-xl font-semibold text-gray-800 mb-3">➕ Novo Lead</h2>
        <form action="/enrich" method="POST" class="flex flex-col sm:flex-row gap-2">
          <input type="email" name="email" required placeholder="E-mail do lead *" 
                 class="w-full sm:flex-1 border border-gray-300 p-2 rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <input type="text" name="nome" required placeholder="Nome *" 
                 class="w-full sm:flex-1 border border-gray-300 p-2 rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <input type="text" name="dominio" placeholder="Domínio (ex: empresa.com)" 
                 class="w-full sm:flex-1 border border-gray-300 p-2 rounded text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent">
          <button type="submit" class="w-full sm:w-auto bg-blue-600 text-white px-6 py-2 rounded hover:bg-blue-700 transition-smooth text-sm sm:text-base font-medium">
            🔍 Enriquecer
          </button>
        </form>
      </div>

      <!-- Mensagem de Erro -->
      <% if (error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <!-- Notificação Toast -->
      <div id="notification" class="fixed bottom-4 right-4 z-50 hidden transition-smooth"></div>

    <!-- Detalhes do Lead (server-rendered ou clique na tabela) -->
    <% if (lead) { %>
      <div id="leadDetail" class="mt-6">
        <h2 class="text-xl font-semibold mb-3">Lead Enriquecido</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white">
            <thead>
              <tr class="bg-gray-100">
                <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium text-gray-700">Campo</th>
                <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium text-gray-700">Valor</th>
              </tr>
            </thead>
            <tbody id="leadDetailBody">
              <% 
                const formatValue = (val, key) => {
                  if (val === null || val === undefined) return '<span class="text-gray-400 italic">—</span>';
                  if (Array.isArray(val)) {
                    if (val.length === 0) return '<span class="text-gray-400 italic">Nenhum</span>';
                    // Se for array de objetos (serperRawData), mostra resumo
                    if (typeof val[0] === 'object' && val[0] !== null) {
                      return '<span class="text-blue-600 font-medium">' + val.length + ' registro(s)</span> <button onclick="event.stopPropagation(); toggleDetail(this)" class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded hover:bg-blue-200">Ver detalhes</button><div class="hidden mt-1"><pre class="text-xs bg-gray-50 p-2 rounded max-h-60 overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre></div>';
                    }
                    return val.map(v => '<span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded mr-1 mb-1">' + escapeHtml(String(v)) + '</span>').join('');
                  }
                  if (typeof val === 'boolean') return val ? '<span class="text-green-600 font-bold">✅ Sim</span>' : '<span class="text-red-500">❌ Não</span>';
                  if (typeof val === 'object') {
                    // rdap: mostrar campos principais
                    if (val.registrantName || val.registrantEmail) {
                      const lines = [];
                      if (val.registrantName) lines.push('Titular: ' + val.registrantName);
                      if (val.registrantEmail) lines.push('E-mail: ' + val.registrantEmail);
                      if (val.registrationDate) lines.push('Registro: ' + new Date(val.registrationDate).toLocaleDateString('pt-BR'));
                      if (val.expirationDate) lines.push('Expiração: ' + new Date(val.expirationDate).toLocaleDateString('pt-BR'));
                      if (val.nameservers && val.nameservers.length) lines.push('NS: ' + val.nameservers.join(', '));
                      if (val.source) lines.push('Fonte: ' + val.source);
                      return lines.map(l => '<div class="text-xs text-gray-700">' + escapeHtml(l) + '</div>').join('') +
                        ' <button onclick="event.stopPropagation(); toggleDetail(this)" class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded hover:bg-gray-200 mt-1">JSON completo</button><div class="hidden mt-1"><pre class="text-xs bg-gray-50 p-2 rounded max-h-60 overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre></div>';
                    }
                    return '<pre class="text-xs bg-gray-50 p-2 rounded max-w-lg overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre>';
                  }
                  return escapeHtml(String(val));
                };
                const escapeHtml = (str) => {
                  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
                };
                const labelMap = {
                  id: 'ID', email: 'E-mail', emailMasked: 'E-mail Mascarado', name: 'Nome',
                  domain: 'Domínio', mxStatus: 'MX Ativo', status: 'Status',
                  technologies: 'Tecnologias Detectadas', socialLinks: 'Links Sociais',
                  socialProfileSummaries: 'Resumos de Perfis Sociais', exposedEmails: 'E-mails Expostos',
                  exposedPhones: 'Telefones Expostos', exposedAdminPaths: 'Caminhos Admin Expostos',
                  exposedDocuments: 'Documentos Expostos', exposedConfigFiles: 'Arquivos de Config Expostos',
                  nameMentions: 'Menções do Nome', nameMentionUrls: 'URLs de Menções',
                  dorkFindings: 'Dorks Encontrados',
                  dnsMxRecords: 'Registros MX', dnsARecords: 'Registros A',
                  dnsAaaaRecords: 'Registros AAAA', dnsCnameRecords: 'Registros CNAME',
                  dnsTxtRecords: 'Registros TXT',
                  serperRawData: 'Dados Brutos (Serper)',
                  rdap: 'Registro RDAP (Domínio)',
                  created_at: 'Criado em', updated_at: 'Atualizado em'
                };
                Object.keys(lead).forEach(function(key) {
                  const label = labelMap[key] || key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
              %>
              <tr class="hover:bg-gray-50">
                <td class="border border-gray-300 px-4 py-2 text-sm font-medium text-gray-600"><%= label %></td>
                <td class="border border-gray-300 px-4 py-2 text-sm text-gray-800"><%- formatValue(lead[key], key) %></td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    <% } else { %>
      <div id="leadDetail" class="mt-6 hidden">
        <h2 id="leadDetailTitle" class="text-xl font-semibold mb-3">Detalhes do Lead</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white">
            <thead>
              <tr class="bg-gray-100">
                <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium text-gray-700">Campo</th>
                <th class="border border-gray-300 px-4 py-2 text-left text-sm font-medium text-gray-700">Valor</th>
              </tr>
            </thead>
            <tbody id="leadDetailBody"></tbody>
          </table>
        </div>
      </div>
    <% } %>

      <% if (!lead && !error && (!Array.isArray(leads) || leads.length === 0)) { %>
        <div class="p-6 bg-gray-50 rounded-lg border border-gray-200 text-center">
          <p class="text-gray-400">✨ Preencha os campos acima para enriquecer um novo lead.</p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Modal de Edição Responsivo -->
  <div id="editModal" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4" style="display:none;">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-sm sm:max-w-md">
      <div class="p-4 sm:p-6">
        <h3 class="text-lg font-bold mb-4">✏️ Editar Lead #<span id="editLeadId"></span></h3>
        <form id="editForm" onsubmit="event.preventDefault(); submitUpdate();">
          <input type="email" id="editEmail" required placeholder="E-mail *" 
                 class="w-full border border-gray-300 p-2 rounded mb-3 text-sm focus:ring-2 focus:ring-blue-500">
          <input type="text" id="editNome" placeholder="Nome" 
                 class="w-full border border-gray-300 p-2 rounded mb-3 text-sm focus:ring-2 focus:ring-blue-500">
          <input type="text" id="editDominio" placeholder="Domínio" 
                 class="w-full border border-gray-300 p-2 rounded mb-4 text-sm focus:ring-2 focus:ring-blue-500">
          <div class="flex flex-col sm:flex-row gap-2 justify-end">
            <button type="button" onclick="closeEdit()" 
                    class="w-full sm:w-auto bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400 transition-smooth">
              Cancelar
            </button>
            <button type="submit" 
                    class="w-full sm:w-auto bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 transition-smooth">
              💾 Salvar
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Dados dos leads
    const LEADS_DATA = <%- JSON.stringify(leads) %>;

    const LABEL_MAP = {
      id: 'ID', email: 'E-mail', emailMasked: 'E-mail Mascarado', name: 'Nome',
      domain: 'Domínio', mxStatus: 'MX Ativo', status: 'Status',
      technologies: 'Tecnologias Detectadas', socialLinks: 'Links Sociais',
      socialProfileSummaries: 'Resumos de Perfis Sociais', exposedEmails: 'E-mails Expostos',
      exposedPhones: 'Telefones Expostos', exposedAdminPaths: 'Caminhos Admin Expostos',
      exposedDocuments: 'Documentos Expostos', exposedConfigFiles: 'Arquivos de Config Expostos',
      nameMentions: 'Menções do Nome', nameMentionUrls: 'URLs de Menções',
      dorkFindings: 'Dorks Encontrados',
      dnsMxRecords: 'Registros MX', dnsARecords: 'Registros A',
      dnsAaaaRecords: 'Registros AAAA', dnsCnameRecords: 'Registros CNAME',
      dnsTxtRecords: 'Registros TXT',
      serperRawData: 'Dados Brutos (Serper)',
      rdap: 'Registro RDAP (Domínio)',
      foundDocuments: 'Documentos Encontrados',
      discoveredUrls: 'URLs Descobertas',
      created_at: 'Criado em', updated_at: 'Atualizado em'
    };

    function escapeHtml(str) {
      if (!str) return '';
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function linkify(str) {
      return str.replace(/(https?:\/\/[^\s<")]+)/g, '<a href="$1" target="_blank" class="text-blue-600 hover:underline">$1</a>');
    }

    function formatValue(val, key) {
      if (val === null || val === undefined) return '<span class="text-gray-400 italic">—</span>';
      if (Array.isArray(val)) {
        if (val.length === 0) return '<span class="text-gray-400 italic">Nenhum</span>';
        if (typeof val[0] === 'object' && val[0] !== null) {
          return '<span class="text-blue-600 font-medium">' + val.length + ' registro(s)</span> <button onclick="event.stopPropagation(); toggleDetail(this)" class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded hover:bg-blue-200">Ver detalhes</button><div class="hidden mt-1"><pre class="text-xs bg-gray-50 p-2 rounded max-h-60 overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre></div>';
        }
        return val.map(function(v) { return '<span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-0.5 rounded mr-1 mb-1">' + linkify(escapeHtml(String(v))) + '</span>'; }).join('');
      }
      if (typeof val === 'boolean') return val ? '<span class="text-green-600 font-bold">✅ Sim</span>' : '<span class="text-red-500">❌ Não</span>';
      if (typeof val === 'object') {
        // serperRawData: mostrar como tabela
        if (key === 'serperRawData' && val.items && Array.isArray(val.items)) {
          var html = '<div class="text-xs text-gray-700 mb-2"><strong>Query:</strong> ' + escapeHtml(val.query || '') + ' | <strong>Total:</strong> ' + (val.totalResults || 0) + ' resultados</div>';
          if (val.items.length > 0) {
            html += '<table class="w-full text-xs border-collapse bg-white"><thead><tr class="bg-gray-100">';
            html += '<th class="border border-gray-300 px-2 py-1 text-left">#</th>';
            html += '<th class="border border-gray-300 px-2 py-1 text-left">Título</th>';
            html += '<th class="border border-gray-300 px-2 py-1 text-left">URL</th>';
            html += '<th class="border border-gray-300 px-2 py-1 text-left">Snippet</th>';
            html += '<th class="border border-gray-300 px-2 py-1 text-left">Domínio</th>';
            html += '</tr></thead><tbody>';
            val.items.forEach(function(item) {
              html += '<tr class="hover:bg-gray-50">';
              html += '<td class="border border-gray-300 px-2 py-1">' + (item.position || '') + '</td>';
              html += '<td class="border border-gray-300 px-2 py-1 max-w-[200px] overflow-hidden text-ellipsis whitespace-nowrap" title="' + escapeHtml(item.title || '') + '">' + escapeHtml(item.title || '') + '</td>';
              html += '<td class="border border-gray-300 px-2 py-1 max-w-[250px] overflow-hidden text-ellipsis whitespace-nowrap"><a href="' + escapeHtml(item.url || '') + '" target="_blank" class="text-blue-600 hover:underline" title="' + escapeHtml(item.url || '') + '">' + escapeHtml(item.url || '') + '</a></td>';
              html += '<td class="border border-gray-300 px-2 py-1 max-w-[300px] overflow-hidden text-ellipsis whitespace-nowrap" title="' + escapeHtml(item.snippet || '') + '">' + escapeHtml(item.snippet || '') + '</td>';
              html += '<td class="border border-gray-300 px-2 py-1">' + escapeHtml(item.domain || '') + '</td>';
              html += '</tr>';
            });
            html += '</tbody></table>';
          } else {
            html += '<span class="text-gray-400 italic">Nenhum item</span>';
          }
          return html;
        }
        if (val.registrantName || val.registrantEmail) {
          var lines = [];
          if (val.registrantName) lines.push('Titular: ' + val.registrantName);
          if (val.registrantEmail) lines.push('E-mail: ' + val.registrantEmail);
          if (val.registrationDate) lines.push('Registro: ' + new Date(val.registrationDate).toLocaleDateString('pt-BR'));
          if (val.expirationDate) lines.push('Expiração: ' + new Date(val.expirationDate).toLocaleDateString('pt-BR'));
          if (val.nameservers && val.nameservers.length) lines.push('NS: ' + val.nameservers.join(', '));
          if (val.source) lines.push('Fonte: ' + val.source);
          return lines.map(function(l) { return '<div class="text-xs text-gray-700">' + escapeHtml(l) + '</div>'; }).join('') +
            ' <button onclick="event.stopPropagation(); toggleDetail(this)" class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded hover:bg-gray-200 mt-1">JSON completo</button><div class="hidden mt-1"><pre class="text-xs bg-gray-50 p-2 rounded max-h-60 overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre></div>';
        }
        return '<pre class="text-xs bg-gray-50 p-2 rounded max-w-lg overflow-auto">' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre>';
      }
      return linkify(escapeHtml(String(val)));
    }

    function toggleDetail(btn) {
      var container = btn.nextElementSibling;
      if (container && container.classList) {
        container.classList.toggle('hidden');
        btn.textContent = container.classList.contains('hidden') ? 'Ver detalhes' : 'Ocultar';
      }
    }

    var currentLeadId = null;

    function showDetail(lead) {
      var detailDiv = document.getElementById('leadDetail');
      var detailBody = document.getElementById('leadDetailBody');
      var detailTitle = document.getElementById('leadDetailTitle');

      if (currentLeadId === lead.id) {
        detailDiv.classList.add('hidden');
        currentLeadId = null;
        return;
      }

      currentLeadId = lead.id;
      if (detailTitle) detailTitle.textContent = '🔍 Detalhes do Lead #' + (lead.id || '');
      detailBody.innerHTML = Object.keys(lead).map(function(key) {
        var label = LABEL_MAP[key] || key.replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
        return '<tr class="hover:bg-gray-50">' +
          '<td class="border border-gray-300 px-3 py-2 text-sm font-medium text-gray-600">' + label + '</td>' +
          '<td class="border border-gray-300 px-3 py-2 text-sm text-gray-800">' + formatValue(lead[key], key) + '</td>' +
        '</tr>';
      }).join('');
      detailDiv.classList.remove('hidden');
      detailDiv.scrollIntoView({ behavior: 'smooth' });
    }

    async function deleteLead(id) {
      if (!confirm('⚠️ Tem certeza que deseja excluir o lead #' + id + '?')) return;
      try {
        var resp = await fetch('/' + id, { method: 'DELETE' });
        var data = await resp.json();
        if (resp.ok && data.success) {
          var row = document.querySelector('tr[data-lead-id="' + id + '"]');
          if (row) row.remove();
          var detailDiv = document.getElementById('leadDetail');
          var title = document.getElementById('leadDetailTitle');
          if (title && title.textContent.includes('#' + id)) {
            detailDiv.classList.add('hidden');
          }
          showNotification(true, '✅ Lead excluído com sucesso!');
          setTimeout(() => location.reload(), 1000);
        } else {
          showNotification(false, data.message || data.error || 'Erro ao excluir lead.');
        }
      } catch (e) {
        showNotification(false, '❌ Erro ao excluir lead.');
      }
    }

    var editingLeadId = null;

    function openEditById(id) {
      var lead = LEADS_DATA.find(function(l) { return l.id === id; });
      if (!lead) return;
      openEdit(lead);
    }

    function openEdit(lead) {
      editingLeadId = lead.id;
      document.getElementById('editLeadId').textContent = lead.id;
      document.getElementById('editEmail').value = lead.email || '';
      document.getElementById('editNome').value = lead.name || '';
      document.getElementById('editDominio').value = lead.domain || '';
      document.getElementById('editModal').style.display = 'flex';
    }

    function closeEdit() {
      document.getElementById('editModal').style.display = 'none';
      editingLeadId = null;
    }

    async function submitUpdate() {
      var email = document.getElementById('editEmail').value;
      var nome = document.getElementById('editNome').value;
      var dominio = document.getElementById('editDominio').value;
      try {
        var resp = await fetch('/' + editingLeadId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, dominio: dominio, nome: nome })
        });
        if (resp.ok) {
          closeEdit();
          showNotification(true, '✅ Lead atualizado com sucesso!');
          setTimeout(() => location.reload(), 800);
        } else {
          showNotification(false, '❌ Erro ao atualizar lead.');
        }
      } catch (e) {
        showNotification(false, '❌ Erro ao atualizar lead.');
      }
    }

    function showNotification(success, message) {
      var el = document.getElementById('notification');
      el.innerHTML = message;
      el.className = 'fixed bottom-4 right-4 z-50 p-3 rounded-lg shadow-lg text-sm ' + 
                    (success ? 'bg-green-500 text-white' : 'bg-red-500 text-white');
      el.classList.remove('hidden');
      setTimeout(function() { el.classList.add('hidden'); }, 4000);
    }

    // Event listeners para clicks nas linhas da tabela
    document.querySelectorAll('tr[data-lead-id]').forEach(function(row) {
      row.addEventListener('click', function(e) {
        if (e.target.tagName === 'BUTTON') return;
        var leadId = parseInt(this.getAttribute('data-lead-id'));
        var lead = LEADS_DATA.find(function(l) { return l.id === leadId; });
        if (lead) showDetail(lead);
      });
    });

    // Fechar modal ao clicar fora
    window.onclick = function(event) {
      var modal = document.getElementById('editModal');
      if (event.target === modal) {
        closeEdit();
      }
    }
  </script>
</body>
</html>