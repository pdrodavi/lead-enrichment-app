# =============================================================================
# Lead Enrichment App - Configuração de Ambiente
# =============================================================================
# Copie este arquivo para .env e ajuste os valores:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/Mac)
# =============================================================================

# Porta do servidor web (frontend Node.js)
# O container Docker usa porta 3000 (mapeada para 3032 no docker-compose)
PORT=3000

# URL base da API de Lead Enrichment (back-end Java)
# A API segue a especificação em openapi.yaml
# Endpoints: GET /, GET /{id}, POST /enrich, PUT /{id}, DELETE /{id}, GET /domain/{domain}
#
# Produção:
LEAD_ENRICHMENT_API_URL=https://api-lead-enrichment.pdroti.solutions/api/v1/leads
#
# Desenvolvimento local (back-end Java rodando em http://localhost:8081):
# LEAD_ENRICHMENT_API_URL=http://localhost:8081/api/v1/leads

# Chave de API para autenticação (enviada no header X-API-KEY)
# Obtenha sua chave em: https://pdroti.solutions
LEAD_ENRICHMENT_API_KEY=sua-chave-aqui
