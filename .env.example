# Chave de API para autenticação (header X-API-KEY)
# Obtenha sua chave em: https://pdroti.solutions
LEAD_ENRICHMENT_API_KEY=sua-chave-aqui

# URL base da API de Lead Enrichment
# Produção: https://api-lead-enrichment.pdroti.solutions/api/v1/leads
# Desenvolvimento local: http://localhost:8081/api/v1/leads
LEAD_ENRICHMENT_API_URL=https://api-lead-enrichment.pdroti.solutions/api/v1/leads

# Porta do servidor web (frontend)
PORT=3000
